# ============================================================
# .env - Umgebungsvariablen für Docker Compose
# NIEMALS ins Git committen!
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=mydb
POSTGRES_USER=myuser
POSTGRES_PASSWORD=supersecret

# --- MariaDB / MySQL ---
MYSQL_DATABASE=mydb
MYSQL_USER=myuser
MYSQL_PASSWORD=supersecret
MYSQL_ROOT_PASSWORD=rootsecret
